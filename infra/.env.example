# Secrets voor de docker-compose-stack. Kopieer dit bestand naar infra/.env (gitignored)
# en vul echte waarden in voor productie. docker compose leest infra/.env automatisch.
# De waarden hieronder zijn de POC-dev-defaults.

# Postgres-wachtwoord (gebruiker 'cc'). De backend bouwt hiermee zijn connectionstring.
POSTGRES_PASSWORD=changeme-dev

# Keycloak bootstrap-admin (gebruiker 'admin').
KEYCLOAK_ADMIN_PASSWORD=changeme-dev

# ARI-wachtwoord (gebruiker 'cc-backend'). De Asterisk-entrypoint vult hiermee ari.conf in
# én de backend gebruikt dezelfde waarde (Ari__Password), dus ze blijven vanzelf gelijk.
ARI_PASSWORD=changeme-dev

# Gedeeld SIP-wachtwoord voor de agent-endpoints (pjsip.conf) én nieuwe/geseede agents in de DB
# (backend Agents__DefaultSipPassword). Beide kanten lezen deze ene waarde.
AGENT_SIP_PASSWORD=changeme-dev

# IP van het SBC-interface richting Asterisk (vult pjsip.conf in; vervangt de oude handmatige sed).
SBC_IP=172.16.0.4

# ICE-NAT-mapping voor WebRTC (rtp.conf): privé-IP => publiek IP van de VM. Nodig bij 1:1 NAT
# (Azure); vervangt de oude handmatige rtp.conf-edit. Leeg laten bij een opstelling zonder NAT.
RTP_PRIVATE_IP=172.16.0.5
RTP_PUBLIC_IP=20.107.0.204

# 5060-hardening (optioneel): bron-IP-allowlist voor inkomende SIP (comma-gescheiden CIDR's).
# Leeg = geen ACL (primaire poort-gate is de NSG). LET OP: geldt óók voor WS-agents — pas
# aanzetten als WS via de reverse proxy (localhost) loopt, samen met de TLS-deploy:
# SIP_ACL_PERMIT=127.0.0.1/8,172.16.0.0/24
SIP_ACL_PERMIT=

# --- coturn/TURN (WebRTC-relay voor thuiswerkers) ---
# Gedeeld geheim; de backend geeft er tijdelijke TURN-credentials mee uit (coturn use-auth-secret).
TURN_SECRET=changeme-dev-turn
# Publieke coturn-IP die de browser bereikt (voor de turn:-URL die de backend teruggeeft).
TURN_PUBLIC_HOST=20.107.0.204
# external-ip voor coturn: publiek[/privaat]-IP van de VM (privaat nodig bij NAT met host-netwerk).
TURN_EXTERNAL_IP=20.107.0.204/172.16.0.5
# Optioneel: TURN-realm (default 'contactcenter').
# TURN_REALM=contactcenter

# --- Caddy / TLS (reverse proxy met Let's Encrypt) ---
# Basisdomein; Caddy regelt certs voor api./auth./sip.<CC_DOMAIN>. Vereist DNS-A-records
# naar het VM-IP en NSG-poorten 80 + 443 open.
CC_DOMAIN=zetadesk.net
# E-mailadres voor Let's Encrypt (verloop-notificaties) — vul je eigen adres in.
CADDY_ACME_EMAIL=you@example.com

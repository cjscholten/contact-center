# Reverse proxy + automatische Let's Encrypt-TLS voor de contact-center-stack.
# Eén cert per subdomein (CC_DOMAIN uit infra/.env). Vereist DNS-A-records
# api./auth./sip.<CC_DOMAIN> -> publiek IP van de VM, en NSG-poorten 80 + 443 open.
{
	email {$CADDY_ACME_EMAIL}
}

# Marketing-website (statisch, uit website/ in de repo — gemount in docker-compose).
# Apex + www; extensieloze URL's werken via try_files (bv. /techniek -> techniek.html).
# Vereist DNS-A-records voor de apex en www. -> VM-IP.
{$CC_DOMAIN}, www.{$CC_DOMAIN} {
	root * /srv/website
	try_files {path} {path}.html
	file_server
}

# Backend-API + SignalR-hub (wss gaat vanzelf mee via de WebSocket-upgrade).
api.{$CC_DOMAIN} {
	reverse_proxy localhost:5080
}

# Keycloak (OIDC). Caddy zet X-Forwarded-*; Keycloak bouwt hiermee https://auth.-URL's.
auth.{$CC_DOMAIN} {
	reverse_proxy localhost:8080
}

# Asterisk: ALLEEN het WebSocket-endpoint /ws (SIP.js) publiek maken — niet /ari,
# dat blijft intern (localhost) voor de backend.
sip.{$CC_DOMAIN} {
	@ws path /ws /ws/*
	handle @ws {
		reverse_proxy localhost:8088
	}
	handle {
		respond "Not found" 404
	}
}
